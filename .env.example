# =============================================================================
# UniRide — Environment template (NO real secrets — copy to .env and fill in)
# Generate JWT secrets: cd backend && node scripts/generateSecrets.js
# =============================================================================

# --- Backend (Render / Railway) ---
NODE_ENV=development
PORT=4000

MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/uniride?retryWrites=true&w=majority

JWT_SECRET=
JWT_REFRESH_SECRET=
QR_ENCRYPTION_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=UniRide <onboarding@resend.dev>

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis (optional locally; use Upstash in production)
REDIS_URL=redis://localhost:6379

# CORS
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
ALLOW_VERCEL_PREVIEWS=true

# Payments (optional until enabled)
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=

# Admin seed (run: npm run seed:admin)
ADMIN_EMAIL=admin@uniride.local
ADMIN_PASSWORD=

# --- Frontend (Vercel) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
