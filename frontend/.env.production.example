# =============================================================================
# Vercel Production — set ALL variables in Project → Settings → Environment Variables
# Apply to: Production, Preview, Development
# =============================================================================

# Railway or Render backend (REQUIRED) — must include /api suffix
NEXT_PUBLIC_API_URL=https://your-app.up.railway.app/api

# Socket.io (REQUIRED in production)
NEXT_PUBLIC_SOCKET_URL=https://your-app.up.railway.app

# Supabase (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Legacy alias (optional if ANON_KEY is set)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional
# NEXT_PUBLIC_APP_VERSION=1.0.0
# NEXT_PUBLIC_FRONTEND_URL=https://your-app.vercel.app
