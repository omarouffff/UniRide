# Copy to .env.local for local development, or set these in Vercel → Project → Settings → Environment Variables

# Production backend (Render / Railway) — required on Vercel
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api
NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api

# Socket.io (optional — defaults to API host without /api)
NEXT_PUBLIC_SOCKET_URL=https://your-backend.onrender.com

# Local development example:
# NEXT_PUBLIC_API_URL=http://localhost:4000/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
