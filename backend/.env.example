# Backend environment variables for UniRide - University Transportation SaaS
PORT=4000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/uniride?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/uniride?retryWrites=true&w=majority

# Redis for caching and sessions
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=replace-with-a-strong-random-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
QR_ENCRYPTION_SECRET=replace-with-a-different-strong-random-string

# Email + security
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@uniride.com
SENTRY_DSN=
DEPLOYMENT_VERSION=your-deployment-version

# Cloudinary for image storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Service (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@uniride.com

# Payment Providers
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_AUTH_ENDPOINT=https://accept.paymobsolutions.com/api/auth/tokens
PAYMOB_HMAC_SECRET=your-paymob-hmac-secret
PAYMOB_INTEGRATION_ID=your-paymob-integration-id
PAYMOB_IFRAME_ID=your-paymob-iframe-id
FAWRY_MERCHANT_CODE=your-fawry-merchant-code
FAWRY_SECURITY_KEY=your-fawry-security-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Frontend URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://yourdomain.com

# CORS Configuration (comma-separated; include your Vercel production URL)
FRONTEND_URL=https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
# Vercel preview deployments (*.vercel.app) are allowed by default unless ALLOW_VERCEL_PREVIEWS=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Configuration
ADMIN_EMAIL=admin@uniride.com
ADMIN_PASSWORD_TEMP=TempPassword123!

# Log Level
LOG_LEVEL=debug

# Feature Flags
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_REAL_TIME=true
