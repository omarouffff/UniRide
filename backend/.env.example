# Backend environment variables for UNI Transportation MVP
PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/uni_transportation
# MONGODB_URI is also supported for backward compatibility.
MONGODB_URI=mongodb://localhost:27017/uni_transportation
JWT_SECRET=replace-with-a-strong-random-string
JWT_EXPIRES_IN=7d
QR_ENCRYPTION_SECRET=replace-with-a-different-strong-random-string
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_SECRET is also supported for Render/Cloud Run naming conventions.
CLOUDINARY_SECRET=your-api-secret
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000
