NODE_ENV=development
PORT=4000

# =============================================================================
# SUPABASE POSTGRES — choose ONE setup (see PRODUCTION_ENV.md)
# =============================================================================

# OPTION A (recommended for Railway): Direct connection — one URL for app + migrations
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# OPTION B: Transaction pooler (6543) for app + direct for migrations
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Local Docker Compose only:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/uniride
# DIRECT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/uniride

# =============================================================================
# SUPABASE AUTH (required in production)
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# APP
# =============================================================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
ALLOW_VERCEL_PREVIEWS=true

REDIS_URL=redis://localhost:6379
QR_ENCRYPTION_SECRET=replace-with-32-char-random-secret-minimum

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

RESEND_API_KEY=
EMAIL_FROM=UniRide <noreply@uniride.app>

PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=

FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=

STRIPE_SECRET_KEY=

ADMIN_EMAIL=admin@uniride.app
ADMIN_NAME=UniRide Admin

# DB_CONNECT_RETRIES=5
# DB_CONNECT_RETRY_MS=3000
