generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(uuid())
  name                      String
  email                     String    @unique
  phoneNumber               String?
  college                   String?
  academicYear              String?
  profileImage              String?
  passwordHash              String
  role                      UserRole  @default(student)
  status                    UserStatus @default(pending)
  universityId              String?
  idCardImage               String?
  universityIdImage         String?
  universityIdStatus        UniversityVerificationStatus @default(pending)
  reviewedAt                DateTime?
  reviewNotes               String?
  noShowCount               Int       @default(0)
  waitingListPosition       Int?
  isActive                  Boolean   @default(true)
  emailVerified             Boolean   @default(false)
  emailVerificationToken    String?
  emailVerificationExpires  DateTime?
  emailVerificationLastSentAt DateTime?
  passwordResetToken        String?
  passwordResetExpires      DateTime?
  twoFactorEnabled          Boolean   @default(false)
  twoFactorSecret           String?
  failedLoginAttempts       Int       @default(0)
  lockUntil                 DateTime?
  sessions                  Session[]
  bookings                  Booking[]
  payments                  Payment[]
  notifications             Notification[]
  universityVerifications   UniversityVerification[]
  tripsDriven               Trip[]    @relation("DriverTrips")
  buses                     Bus[]     @relation("DriverBuses")
  auditLogs                 AuditLog[]
  qrScans                   QrScan[]
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

enum UserRole {
  student
  admin
  driver
}

enum UserStatus {
  pending
  approved
  rejected
}

enum UniversityVerificationStatus {
  pending
  approved
  verified
  rejected
}

model Session {
  id               String   @id @default(uuid())
  tokenId          String   @unique
  refreshTokenHash String
  ip               String?
  userAgent        String?
  deviceName       String?  @db.VarChar(100)
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())
  expiresAt        DateTime?
  revoked          Boolean  @default(false)
  user             User     @relation(fields: [userId], references: [id])
  userId           String
}

model Trip {
  id             String   @id @default(uuid())
  title          String
  pickupPoint    String
  destination    String
  busNumber      String
  driver         User?    @relation("DriverTrips", fields: [driverId], references: [id])
  driverId       String?
  capacity       Int
  confirmedCount Int      @default(0)
  departureTime  DateTime
  isActive       Boolean  @default(true)
  bookings       Booking[]
  waitingListItems WaitingList[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([departureTime])
}

model Booking {
  id              String    @id @default(uuid())
  user            User      @relation(fields: [userId], references: [id])
  userId          String
  trip            Trip?     @relation(fields: [tripId], references: [id])
  tripId          String?
  pickupPoint     String
  destination     String
  travelDate      DateTime
  cancelledAt     DateTime?
  seat            String?
  status          BookingStatus @default(waiting)
  waitingPosition Int?
  noShow          Boolean   @default(false)
  boardedAt       DateTime?
  qrPayload       String?
  route           String
  payment         Payment[]
  qrScans         QrScan[]
  waitingListItem WaitingList?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([userId])
  @@index([tripId])
  @@index([status])
  @@index([travelDate])
}

enum BookingStatus {
  confirmed
  waiting
  cancelled
}

model Payment {
  id                String      @id @default(uuid())
  user              User        @relation(fields: [userId], references: [id])
  userId            String
  booking           Booking?    @relation(fields: [bookingId], references: [id])
  bookingId         String?
  amount            Decimal     @db.Decimal(12, 2)
  currency          String      @default("EGP")
  method            PaymentMethod
  status            PaymentStatus @default(pending)
  reference         String      @unique
  proofImage        String?
  description       String?
  metadata          Json?
  transactionId     String?
  invoiceUrl        String?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  @@index([userId])
  @@index([status])
}

enum PaymentMethod {
  card
  wallet
  paymob
  fawry
  stripe
  cash
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

model Bus {
  id             String   @id @default(uuid())
  busNumber      String   @unique
  capacity       Int
  make           String?
  model          String?
  licensePlate   String?
  driver         User?    @relation("DriverBuses", fields: [driverId], references: [id])
  driverId       String?
  status         BusStatus @default(active)
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  amenities      String[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum BusStatus {
  active
  inactive
  maintenance
}

model Notification {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  type       NotificationType
  title      String
  message    String
  read       Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([userId])
  @@index([read])
}

enum NotificationType {
  booking_confirmed
  waiting_promoted
  payment_success
  trip_cancelled
  password_changed
  general
}

model UniversityVerification {
  id                String   @id @default(uuid())
  user              User     @relation(fields: [userId], references: [id])
  userId            String
  studentNumber     String
  universityIdImage String
  status            UniversityVerificationStatus @default(pending)
  notes             String?
  submittedAt       DateTime @default(now())
  reviewedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Analytics {
  id               String   @id @default(uuid())
  date             DateTime @default(now())
  totalBookings    Int      @default(0)
  confirmedBookings Int     @default(0)
  cancelledBookings Int     @default(0)
  totalRevenue     Decimal  @db.Decimal(12, 2) @default("0.00")
  activeUsers      Int      @default(0)
  newUsers         Int      @default(0)
  completedTrips   Int      @default(0)
  noShowCount      Int      @default(0)
  averageOccupancy Decimal  @db.Decimal(5, 2) @default("0.00")
  peakBookingTime  String?
  topRoutes        Json?
  metrics          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([date])
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WaitingList {
  id       String   @id @default(uuid())
  booking  Booking  @relation(fields: [bookingId], references: [id])
  bookingId String  @unique
  trip     Trip?    @relation(fields: [tripId], references: [id])
  tripId   String?
  position Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QrScan {
  id         String   @id @default(uuid())
  booking    Booking  @relation(fields: [bookingId], references: [id])
  bookingId  String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  scannedAt  DateTime @default(now())
  location   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
